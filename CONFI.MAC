	ORG	0100H
;
;CONFI UTILITY
;
;DASM'ED 930421 THORBJOERN RAVN ANDERSEN
;CLAUDE'd 260302 THORBJOERN RAVN ANDERSEN
;
;Build and verify (default matches SW1711 reference binary):
;  ~/git/rc700-sysgen/zmac/bin/zmac  -z --dri CONFI.MAC && cmp zout/CONFI.cim ../rc700-sysgen/rcbios/sw1711_files/CONFI.COM && echo MATCH
;
;Build with WordStar function key mapping (-DWSTHOR) for my patched version giving Wordstar keys:
;  zmac -z --dri -DWSTHOR CONFI.MAC
;
; Room for a patch.
	NOP
	NOP
	NOP

	.z80

;--- 56K BIOS entry points (jump table at DA00h) -----------------------------
CONOUT	EQU	0DA0CH		; BIOS character output
SELDSK	EQU	0DA1BH		; BIOS select disk
SETTRK	EQU	0DA1EH		; BIOS set track
SETSEC	EQU	0DA21H		; BIOS set sector
SETDMA	EQU	0DA24H		; BIOS set DMA address
READ	EQU	0DA27H		; BIOS read sector
WRITE	EQU	0DA2AH		; BIOS write sector
;--- 56K BIOS runtime variables (after jump table) ---------------------------
ADRMOD	EQU	0DA33H		; cursor addressing mode (0=XY, 1=YX)
WR5A	EQU	0DA34H		; SIO Channel A WR5 register copy
WR5B	EQU	0DA35H		; SIO Channel B WR5 register copy
FD0	EQU	0DA37H		; disk type table entry 0 (drive A format)
FDTIMO	EQU	0FFE7H		; floppy motor stop timer reload value
OUTCON	EQU	0F680H		; output conversion table (384 bytes: out+in+semigfx)
;--- Cursor position coordinates (^F col row, each offset by 32) ----------------
X17	EQU	32+17		; column 17
X18	EQU	32+18		; column 18
X32	EQU	32+32		; column 32
Y5	EQU	32+5		; row 5
Y6	EQU	32+6		; row 6
Y7	EQU	32+7		; row 7
Y8	EQU	32+8		; row 8
Y9	EQU	32+9		; row 9
Y10	EQU	32+10		; row 10
Y11	EQU	32+11		; row 11
Y12	EQU	32+12		; row 12
Y13	EQU	32+13		; row 13
Y14	EQU	32+14		; row 14
Y15	EQU	32+15		; row 15
Y16	EQU	32+16		; row 16
Y17	EQU	32+17		; row 17
Y18	EQU	32+18		; row 18
Y19	EQU	32+19		; row 19
Y20	EQU	32+20		; row 20
Y23	EQU	32+23		; row 23

START:
	EX	(SP),HL
	LD	SP,KBDANISH
	PUSH	HL
	LD	DE,WELCOMEMSG
	LD	C,9
	CALL	5
WHICHDISK:	
	LD	DE,DISKACMSG
	LD	C,9
	CALL	5
	LD	C,0AH
	LD	DE,READLINEBUF
	CALL	5
	LD	A,(READLINELEN)
	CP	1
	JR	NZ,WHICHDISK
	LD	HL,READLINECH1
	LD	A,(HL)
	CP	3
	JP	Z,0
	AND	0DFH	; UPCASE CHAR
	CP	'A'
	JR	Z,DISKOK
	CP	'C'
	JR	NZ,WHICHDISK
DISKOK:	
	SUB	'A'
	LD	(DRIVE),A
	XOR	A
	CALL	READCB
	CALL	MAINMENU
LEAVE:	
	LD	C,2	; CLEAR SCREEN
	LD	E,0CH
	CALL	5
	CALL	SETKBMEMORY
	CALL	SETVIDEO
	CALL	SETSIOA
	CALL	SETCTC0
	CALL	SETSIOB
	CALL	SETCTC1
	JP	0
;
;
;
;
MAINMENU:	
	LD	HL,MENUMSG
	LD	DE,1
	LD	BC,6
	CALL	MENU
	RET	NC
	LD	DE,MAINMENU
	PUSH	DE
	CALL	JUMPJPTABLE
	DW	PRINTSETUP
	DW	TERMSETUP
	DW	KBSETUP
	DW	CURSORSETUP
	DW	STOPTIME
	DW	SAVECB
TERMSETUP:	
	LD	HL,TERMMSG
	LD	DE,1
	LD	BC,5
	CALL	MENU
	RET	NC
	LD	DE,TERMSETUP
	PUSH	DE
	CALL	JUMPJPTABLE
	DW	TERMSTOPBIT
	DW	TERMPARITY
	DW	TERMBAUDRATE
	DW	TERMSENDSIZE
	DW	TERMRECSIZE
PRINTSETUP:	
	LD	HL,PRINTERMSG
	LD	DE,1
	LD	BC,4
	CALL	MENU
	RET	NC
	LD	DE,PRINTSETUP
	PUSH	DE
	CALL	JUMPJPTABLE
	DW	PRINTSTOPBIT
	DW	PRINTPARITY
	DW	PRINTBAUDRAT
	DW	PRINTSENDSIZ
	DW	PRINTRECSIZE
TERMSTOPBIT:	
	LD	HL,PSIOA_WR4
	JP	STOPBIT
PRINTSTOPBIT:	
	LD	HL,PSIOB_WR4
	JP	STOPBIT
STOPBIT:	
	LD	A,(HL)
	PUSH	HL
	RRCA
	RRCA
	AND	3
	DEC	A
	LD	HL,STOPBITSMSG
	LD	DE,1
	LD	BC,3
	CALL	MENU
	POP	DE
	RET	NC
	PUSH	DE
	LD	A,L
	RLCA
	RLCA
	LD	B,A
	POP	HL
	LD	A,(HL)
	AND	0F3H
	ADD	A,B
	LD	(HL),A
	RET
TERMPARITY:	
	LD	HL,PSIOA_WR4
	JP	PARITY
PRINTPARITY:	
	LD	HL,PSIOB_WR4
	JP	PARITY
PARITY:	
	LD	A,(HL)
	PUSH	HL
	INC	A
	AND	3
	LD	HL,PARITYMSG
	LD	DE,1
	LD	BC,3
	CALL	MENU
	POP	DE
	RET	NC
	PUSH	DE
	LD	A,L
	XOR	2
	LD	B,A
	POP	HL
	LD	A,(HL)
	AND	0FCH
	ADD	A,B
	LD	(HL),A
	RET
TERMBAUDRATE:	
	LD	HL,BAUDNUMA
	CALL	BAUDRATE
	RET	NC
	LD	A,C
	LD	(COUNT0),A
	LD	A,(PSIOA_WR4)
	AND	'?'
	ADD	A,B
	LD	(PSIOA_WR4),A
	RET
SETCTC0:	
	LD	A,'G'	; TERMINAL BAUD RATE
	OUT	(0CH),A
	LD	A,(COUNT0)
	OUT	(0CH),A
	RET
PRINTBAUDRAT:	
	LD	HL,BAUDNUMB
	CALL	BAUDRATE
	RET	NC
	LD	A,C
	LD	(COUNT1),A
	LD	A,(PSIOB_WR4)
	AND	'?'
	ADD	A,B
	LD	(PSIOB_WR4),A
	RET
SETCTC1:	
	LD	A,'G'	; PRINTER BAUD RATE
	OUT	(0DH),A
	LD	A,(COUNT1)
	OUT	(0DH),A
	RET
BAUDRATE:	
	PUSH	HL
	LD	A,(HL)
	LD	HL,BAUDRATEMSG
	LD	DE,1
	LD	BC,0BH
	CALL	MENU
	POP	DE
	RET	NC
	PUSH	DE
	DEC	HL
	EX	DE,HL
	LD	HL,L0D6A
	ADD	HL,DE
	LD	C,(HL)
	LD	HL,L0D5F
	ADD	HL,DE
	LD	B,(HL)
	POP	HL
	LD	(HL),A
	SCF
	RET
SETSIOA:	
	LD	HL,PSIOA	; TERMINAL PORT
	LD	B,9
	LD	C,0AH
	DI
	OTIR
	EI
	RET
SETSIOB:	
	LD	HL,PSIOB	; PRINTER PORT
	LD	B,0BH
	LD	C,0BH
	DI
	OTIR
	EI
	RET
TERMSENDSIZE:	
	LD	HL,PSIOA_WR5
	CALL	SENDSIZE
	RET	NC
	AND	60H
	LD	(WR5A),A
	RET
TERMRECSIZE:	
	LD	HL,PSIOA_WR3
	CALL	RECSIZE
	RET
PRINTSENDSIZ:	
	LD	HL,PSIOB_WR5
	CALL	SENDSIZE
CHARSIZE:	
	RET	NC
	AND	60H
	LD	(WR5B),A
	RET
PRINTRECSIZE:	
	RET
SENDSIZE:	
	LD	A,(HL)
	PUSH	HL
	RLCA
	RLCA
	RLCA
	AND	3
	LD	HL,BITS2SENDMSG
	LD	DE,1
	LD	BC,4
	CALL	MENU
	POP	DE
	RET	NC
	PUSH	DE
	RRCA
	JP	NC,L02CC
	CCF
	ADD	A,2
L02CC:	
	RRCA
	RRCA
	RRCA
	AND	60H
	LD	B,A
	POP	HL
	LD	A,(HL)
	AND	9FH
	OR	B
	LD	(HL),A
	SCF
	RET
RECSIZE:	
	LD	A,(HL)
	PUSH	HL
	RLCA
	RLCA
	AND	3
	LD	HL,RECSIZEMSG
	LD	DE,1
	LD	BC,4
	CALL	MENU
	POP	DE
	RET	NC
	PUSH	DE
	RRCA
	JP	NC,L02F6
	CCF
	ADD	A,2
L02F6:	
	RRCA
	RRCA
	AND	0C0H
	LD	B,A
	POP	HL
	LD	A,(HL)
	AND	'?'
	ADD	A,B
	LD	(HL),A
	RET
;
;
;
;
KBSETUP:	
	LD	HL,KBMSG
	LD	A,(CONVNUM)
	LD	DE,1
	LD	BC,7
	CALL	MENU
	RET	NC
	LD	(CONVNUM),A
	LD	HL,KBDANISH
	LD	BC,0180H
KBLOOP1:	
	DEC	A
	JP	M,MOVEKBCONFIG
	ADD	HL,BC
	JP	KBLOOP1
MOVEKBCONFIG:	
	LD	DE,CBKB
	LDIR
	RET
SETKBMEMORY:	
	LD	A,(CONVNUM)
	LD	HL,KBDANISH
	LD	BC,0180H
KBLOOP2:	
	DEC	A
	JP	M,MOVEKBMEMORY
	ADD	HL,BC
	JP	KBLOOP2
MOVEKBMEMORY:	
	LD	DE,OUTCON
	LDIR
	RET
CURSORSETUP:	
	LD	HL,CURSORMSG
	LD	DE,1
	LD	BC,2
	CALL	MENU
	RET	NC
	LD	DE,CURSORSETUP
	PUSH	DE
	CALL	JUMPJPTABLE
	DW	CURSORFORM
	DW	CURSXB4Y
CURSORFORM:	
	LD	HL,CURSFORMMSG
	LD	A,(CURSNUM)
	LD	DE,1
	LD	BC,4
	CALL	MENU
	RET	NC
	LD	A,L
	DEC	A
	LD	(CURSNUM),A
	AND	3
	RLCA
	RLCA
	RLCA
	RLCA
	LD	C,A
	LD	A,(PAR4)
	AND	0CFH
	OR	C
	LD	(PAR4),A
	RET
SETVIDEO:	
	LD	A,'@'
	OUT	(01H),A
	LD	A,0
	OUT	(01H),A
	LD	A,(PAR1)
	OUT	(00H),A
	LD	A,(PAR2)
	OUT	(00H),A
	LD	A,(PAR3)
	OUT	(00H),A
	LD	A,(PAR4)
	OUT	(00H),A
	LD	A,'#'
	OUT	(01H),A
	RET
;
;
;
CURSXB4Y:	
	LD	HL,CURSADDRMSG
	LD	A,(XYFLG)
	LD	DE,1
	LD	BC,2
	CALL	MENU
	RET	NC
	LD	(XYFLG),A
	LD	(ADRMOD),A
	RET
;
;
;
;
STOPTIME:	
	LD	HL,STOPTIME1MSG
	CALL	PRINTMENU
	LD	HL,(STPTIM)
	CALL	HLDIV50
	CALL	PRINTHLDEC
	LD	HL,STOPTIME2MSG
	LD	DE,5
	LD	BC,1200
	CALL	MENU
	RET	NC
	CALL	MULT50HL
	LD	(FDTIMO),HL
	LD	(STPTIM),HL
	RET
SAVECB:	
	LD	A,1
	CALL	READCB
	RET
RWSECTOR:	
	OR	A
	JR	Z,RSECTOR
	LD	BC,0
	CALL	WRITE
	JR	CHECKRWRES
RSECTOR:	
	CALL	READ
CHECKRWRES:	
	CP	0
	JP	NZ,BADSECTOR
	RET
READCB:	
	PUSH	AF
	LD	A,(DRIVE)
	CP	2
	JR	Z,READDRIVEC
	POP	AF
	LD	HL,FD0		; DRIVE A FORMAT
	LD	B,(HL)
	PUSH	BC
	PUSH	AF
	IN	A,(14H)
	AND	80H
	JR	Z,MINISYSTEM
	LD	A,0
	JR	SETTRACK0FOR
MINISYSTEM:	
	LD	A,10H
SETTRACK0FOR:	
	LD	(HL),A
	LD	BC,0
	CALL	SELDSK		; BIOS - SELDSK 0
	JP	READCBBLOCKS
READDRIVEC:	
	LD	B,0
	LD	C,2
	CALL	SELDSK		; BIOS - SELDSK 2
READCBBLOCKS:	
	LD	BC,0
	CALL	SETTRK		; SET TRACK
	LD	BC,1
	CALL	SETSEC		; SET SECTOR
	LD	BC,CBBLOCK1
	CALL	SETDMA		; SET DMA
	POP	AF
	PUSH	AF		; POP/PUSH OPERATION CODE IN A
	CALL	RWSECTOR
	LD	BC,CBKB
	CALL	SETDMA		; SET DMA
	LD	BC,2
	CALL	SETSEC		; SET SECTOR
	POP	AF
	PUSH	AF
	CALL	RWSECTOR
	LD	BC,CBBLOCK3
	CALL	SETDMA		; SET DMA
	LD	BC,3
	CALL	SETSEC		; SET SECTOR
	POP	AF
	PUSH	AF
	CALL	RWSECTOR
	LD	BC,CBBLOCK4
	CALL	SETDMA
	LD	BC,4
	CALL	SETSEC
	POP	AF
	CALL	RWSECTOR
	LD	A,(DRIVE)	; DONE WITH R/W.  NOW CLEAN UP
	CP	2
	JP	Z,DONEHD
	LD	HL,FD0		; RESTORE ORIGINAL FLOPPY TYPE
	POP	AF
	LD	(HL),A
	LD	BC,0
	CALL	SELDSK
	RET
DONEHD:	
	LD	B,0
	LD	C,2
	CALL	SELDSK
	RET
MULT10HL:	
	ADD	HL,HL
	LD	D,H
	LD	E,L
	ADD	HL,HL
	ADD	HL,HL
	ADD	HL,DE
	RET
MULT50HL:	
	CALL	MULT10HL
	LD	D,H
	LD	E,L
	ADD	HL,HL
	ADD	HL,HL
	ADD	HL,DE
	RET
HLDIV50:	
	LD	DE,1
	LD	BC,-50
L049D:	
	ADD	HL,BC
	LD	A,H
	OR	L
	JR	Z,HLDIB50C
	INC	DE
	JR	L049D
HLDIB50C:	
	EX	DE,HL
	RET
PRINTHLDEC:	
	LD	B,0
	LD	DE,10000
	CALL	PRINTHLDIVDE
	LD	DE,1000
	CALL	PRINTHLDIVDE
	LD	DE,100
	CALL	PRINTHLDIVDE
	LD	DE,10
	CALL	PRINTHLDIVDE
	LD	DE,1
PRINTHLDIVDE:	
	LD	C,'0'
PRINTHL2:	
	OR	A
	SBC	HL,DE
	JR	C,PRINTHL3
	INC	C
	JR	PRINTHL2
PRINTHL3:	
	ADD	HL,DE
	LD	A,'0'
	CP	C
	JR	Z,PRINTHL4
	LD	B,1
PRINTHL4:	
	XOR	A		; UDSKRIV TEGNET I C, HVISS B=1
	CP	B
	PUSH	AF
	PUSH	HL
	PUSH	BC
	PUSH	DE
	LD	E,C
	LD	C,2
	CALL	NZ,5
	POP	DE
	POP	BC
	POP	HL
	POP	AF
	RET
;
;
;
;
MENU:				; A=CHOSEN ENTRY; HL=MSG, DE=FIRST, BC=NUMBER OF ENTRIES
	PUSH	DE
	PUSH	BC		;
	CALL	PRINTMENU
GETCHOICE:	
	LD	HL,CHOICEMSG
	CALL	PRINTMENU
	LD	HL,0
	LD	(CMDNUMBER),HL
	LD	C,0AH
	LD	DE,READLINEBUF
	CALL	5
	LD	HL,READLINELEN
	LD	A,(HL)
	LD	(CMDLEN),A
	OR	A
	JR	Z,PRINTCRLF	; RETURN ON CR
	INC	HL
	LD	(CMDPTR),HL
MENUNEXTCH:	
	LD	A,(CMDLEN)
	DEC	A
	JP	M,MENUCHECKCMD
	LD	(CMDLEN),A
	LD	HL,(CMDPTR)
	LD	A,(HL)
	INC	HL
	LD	(CMDPTR),HL
	LD	HL,(CMDNUMBER)
	CALL	MULT10HL
	SUB	'0'
	LD	E,A
	LD	D,0
	ADD	HL,DE
	LD	(CMDNUMBER),HL
	JP	MENUNEXTCH
MENUCHECKCMD:	
	LD	HL,(CMDNUMBER)
	POP	BC
	POP	DE
	PUSH	DE
	PUSH	BC
	OR	A
	SBC	HL,DE
	JR	C,BADCHOICE
	ADD	HL,DE
	INC	BC
	OR	A
	SBC	HL,BC
	JP	NC,BADCHOICE
	ADD	HL,BC
	LD	A,L
	DEC	A
	SCF
PRINTCRLF:	
	PUSH	AF
	PUSH	HL
	LD	C,2
	LD	E,0AH
	CALL	5
	LD	C,2
	LD	E,0DH
	CALL	5
	POP	HL
	POP	AF
	POP	BC
	POP	DE
	RET
BADCHOICE:	
	LD	HL,ILLEGALMSG
	CALL	PRINTMENU
	JR	GETCHOICE
READLINEBUF:			; BUFFER FOR READING A LINE OF INPUT
	DB	5
READLINELEN:	
	DB	0
READLINECH1:	
	DB	0,0,0,0,0
CMDPTR:	
	DW	READLINECH1
CMDLEN:	
	DB	0
CMDNUMBER:	
	DB	0,0

JUMPJPTABLE:		; Jump to the routine for the menu item selected.  HL=OFFSET IN JUMP TABLE AFTER CALL
	POP	DE
	DEC	HL
	ADD	HL,HL
	ADD	HL,DE
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	EX	DE,HL
	JP	(HL)

PRINTMENU:	
	LD	(STARREDCMD),A
PRINTNEXTHL:			; PRINT THE NULL TERMINATED STRING POINTED TO BY HL, AND CHECK FOR SPECIAL CODES IN THE PROCESS
	LD	A,(HL)
	OR	A
	RET	Z		; NUL TERMINATES THE STRING
	CP	6		; HVIS ^F SAA UDSKRIV CURSORSAETNING
	CALL	Z,SETCURSORPOS
	CP	5		; HVIS ^E SAA PREFIX MED '*' HVIS DET RIGTIGE NUMMER, ELLERS ' '
	JP	NZ,PRINTPLAINCH
	LD	A,(STARREDCMD)
	DEC	A
	LD	(STARREDCMD),A
	OR	A
	JP	P,PRINTSPACE
	LD	A,'*'
	LD	(STARREDCMD),A	; NO MORE CHECK ON '*'
	JP	PRINTPLAINCH
PRINTSPACE:	
	LD	A,' '
PRINTPLAINCH:	
	CP	1FH
	JR	Z,PRINTBIOS
PRINTBDOS:	
	LD	E,A
	PUSH	HL
	LD	C,2
	CALL	5
	POP	HL
	INC	HL
	JR	PRINTNEXTHL
PRINTBIOS:	
	LD	C,A	; CONTROL CHARACTERS GOES HERE.
	CALL	CONOUT
	INC	HL
	JR	PRINTNEXTHL
SETCURSORPOS:	
	LD	C,A
	CALL	CONOUT	;SEND ^F
	INC	HL
	LD	D,(HL)
	INC	HL
	LD	E,(HL)	;DE = CURSOR POSITION
	LD	A,(ADRMOD)	; CHECK BIOS FOR WHICH FORMAT TO USE.
	OR	A
	JP	NZ,CURSORBCKWRD
	LD	C,D
	CALL	CONOUT
	LD	C,E
	CALL	CONOUT
	RET
CURSORBCKWRD:	
	LD	C,E
	CALL	CONOUT
	LD	C,D
	CALL	CONOUT
	RET
STARREDCMD:	
	DB	0FFH
BADSECTOR:	
	LD	DE,BADSECTORMSG
	LD	C,9
	CALL	5
	JP	0
WELCOMEMSG:	
	DB	0AH,0AH,0DH
	DB	'RC700 CP/M CONFIGURATION UTILITY  VERS 2.1  13.01.83$'
DISKACMSG:	
	DB	0AH,0DH
	DB	'SELECT SYSTEM DISK FOR CONFIGURATION (A/C)? $'

BADSECTORMSG:
	DB	0AH,0DH
	DB	'BAD SECTOR $'
MENUMSG:	
	DB	0CH
	DB	6,X18,Y5,'********** MENU **********',0AH,0DH
	DB	6,X18,Y7,'1: PRINTER PORT',0AH,0DH
	DB	6,X18,Y8,'2: TERMINAL PORT',0AH,0DH
	DB	6,X18,Y9,'3: CONVERSION',0AH,0DH
	DB	6,X18,Y10,'4: CURSOR',0AH,0DH
	DB	6,X18,Y11,'5: MINI MOTOR STOP TIMER',0AH,0DH
	DB	6,X18,Y12,'6: SAVE CONFIGURATION DESCRIPTION',0AH,0DH
	DB	6,X18,Y13,0
TERMMSG:	
	DB	6,X18,Y5,1FH
	DB	6,X18,Y5,'********* TERMINAL PORT *********',0AH,0DH
	DB	6,X18,Y7,'************* MENU **************',0AH,0DH
	DB	6,X18,Y9,'1: NUMBER OF STOP BITS PR. CHARACTER',0AH,0DH
	DB	6,X18,Y10,'2: PARITY',0AH,0DH
	DB	6,X18,Y11,'3: BAUDRATE',0AH,0DH
	DB	6,X18,Y12,'4: NUMBER OF BITS PR. CHARACTER TO TRANSMIT',0AH,0DH
	DB	6,X18,Y13,'5: NUMBER OF BITS PR. CHARACTER TO RECEIVE',0AH,0DH
	DB	6,X18,Y14,0
CURSFORMMSG:	
	DB	6,X18,Y6,1FH
	DB	6,X18,Y7,'******** FORMAT ********',0AH,0DH
	DB	6,X17,Y9,5,'1: BLINKING REVERSE VIDEO',0AH,0DH
	DB	6,X17,Y10,5,'2: BLINKING UNDERLINE',0AH,0DH
	DB	6,X17,Y11,5,'3: REVERSE VIDEO',0AH,0DH
	DB	6,X17,Y12,5,'4: UNDERLINE',0AH,0DH
	DB	6,X18,Y13,0
KBMSG:
	DB	6,X18,Y5,1FH
	DB	6,X18,Y5,'******** CONVERSION TABLE ********',0AH,0DH
	DB	6,X17,Y7,5,'1: DANISH',0AH,0DH
	DB	6,X17,Y8,5,'2: SWEDISH',0AH,0DH
	DB	6,X17,Y9,5,'3: GERMAN',0AH,0DH
	DB	6,X17,Y10,5,'4: UK-ASCII',0AH,0DH
	IFDEF	WSTHOR
	DB	6,X17,Y11,5,'5: US+WS-Th',0AH,0DH
	ELSE
	DB	6,X17,Y11,5,'5: US-ASCII',0AH,0DH
	ENDIF
	DB	6,X17,Y12,5,'6: FRENCH',0AH,0DH
	DB	6,X17,Y13,5,'7: LIBRARY',0AH,0DH
	DB	6,X18,Y14,0
STOPBITSMSG:
	DB	6,X18,Y6,1FH
	DB	6,X18,Y7,'******** STOPBITS ********',0AH,0DH
	DB	6,X17,Y9,5,'1: 1 BIT',0AH,0DH
	DB	6,X17,Y10,5,'2: 1.5 BIT',0AH,0DH
