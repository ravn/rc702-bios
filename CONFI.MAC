	DB	32H,9EH,3AH,0C3H,6,0BH,0C3H,0ABH,4,3AH,9FH,3AH,0B7H,0CAH,24H,31H
	DB	0C1H,1,0D6H,1,0C5H,0CDH,1BH,0BH,0FEH,3AH,0CCH,1BH,0BH,0CDH,10H,5
