;==============================================================================
;= HARDWARE CONFIGURATION BLOCK — Track 0, logical sector 1 (physical 2)     =
;= 128 bytes read from disk by READCB at startup, written back by SAVECB.     =
;= Layout matches INIPARMS.MAC in the BIOS source (rcbios/src/INIPARMS.MAC). =
;= All values are zero in the .COM file; overwritten from disk at runtime.    =
;==============================================================================
CBBLOCK1	EQU	$
CBBLOCK3	EQU	$+2*128
CBBLOCK4	EQU	$+3*128
;
;--- Z80 CTC baud rate generators (Ch0-1) and system timers (Ch2-3) -----------
;
	DB	0		; +0:  MODE0  - CTC Ch0 timer mode (0x47)
COUNT0:
	DB	0		; +1:  COUNT0 - CTC Ch0 divisor (SIO-A baud rate)
	DB	0		; +2:  MODE1  - CTC Ch1 timer mode (0x47)
COUNT1:
	DB	0		; +3:  COUNT1 - CTC Ch1 divisor (SIO-B baud rate)
	DB	0		; +4:  MODE2  - CTC Ch2 counter mode (0xD7, display)
	DB	0		; +5:  COUNT2 - CTC Ch2 count (0x01)
	DB	0		; +6:  MODE3  - CTC Ch3 counter mode (0xD7, floppy)
	DB	0		; +7:  COUNT3 - CTC Ch3 count (0x01)
;
;--- Z80 SIO Channel A init block (9 bytes, OTIR to port 0Ah) ----------------
;  BIOS role: printer (LST:).  CONFI menu: "TERMINAL PORT" (labels swapped).
;
PSIOA:
	DB	0		; +8:  PSIOA[0] - WR0 channel reset (0x18)
	DB	0		; +9:  PSIOA[1] - select WR4 (0x04)
PSIOA_WR4:
	DB	0		; +10: PSIOA[2] - WR4: clock mode | stop bits | parity
	DB	0		; +11: PSIOA[3] - select WR3 (0x03)
PSIOA_WR3:
	DB	0		; +12: PSIOA[4] - WR3: RX bits/char, auto enable, RX enable
	DB	0		; +13: PSIOA[5] - select WR5 (0x05)
PSIOA_WR5:
	DB	0		; +14: PSIOA[6] - WR5: TX bits/char, DTR, RTS, TX enable
	DB	0		; +15: PSIOA[7] - select WR1 (0x01)
	DB	0		; +16: PSIOA[8] - WR1: interrupt enables (0x1B)
;
;--- Z80 SIO Channel B init block (11 bytes, OTIR to port 0Bh) ---------------
;  BIOS role: terminal (RDR:/PUN:).  CONFI menu: "PRINTER PORT" (swapped).
;
PSIOB:
	DB	0		; +17: PSIOB[0]  - WR0 channel reset (0x18)
	DB	0		; +18: PSIOB[1]  - select WR2 (0x02)
	DB	0		; +19: PSIOB[2]  - WR2 interrupt vector (0x10)
	DB	0		; +20: PSIOB[3]  - select WR4 (0x04)
PSIOB_WR4:
	DB	0		; +21: PSIOB[4]  - WR4: clock mode | stop bits | parity
	DB	0		; +22: PSIOB[5]  - select WR3 (0x03)
PSIOB_WR3:
	DB	0		; +23: PSIOB[6]  - WR3: RX bits/char, auto enable
	DB	0		; +24: PSIOB[7]  - select WR5 (0x05)
PSIOB_WR5:
	DB	0		; +25: PSIOB[8]  - WR5: TX bits/char, DTR, RTS
	DB	0		; +26: PSIOB[9]  - select WR1 (0x01)
	DB	0		; +27: PSIOB[10] - WR1: interrupt enables (0x1F)
;
;--- AM9517 DMA controller mode registers ------------------------------------
;
	DB	0		; +28: DMODE0 - DMA Ch0 mode (0x48, WD1000 hard disk)
	DB	0		; +29: DMODE1 - DMA Ch1 mode (0x49, floppy disk)
	DB	0		; +30: DMODE2 - DMA Ch2 mode (0x4A, display)
	DB	0		; +31: DMODE3 - DMA Ch3 mode (0x4B, display)
;
;--- Intel 8275 CRT controller parameters ------------------------------------
;
PAR1:
	DB	0		; +32: PAR1 - 80 chars/row (0x4F)
PAR2:
	DB	0		; +33: PAR2 - 25 rows/frame (0x98)
PAR3:
	DB	0		; +34: PAR3 - underline pos, char height (0x7A)
PAR4:
	DB	0		; +35: PAR4 - cursor format in bits 4-5 (0x4D)
;
;--- uPD765 FDC specify parameters -------------------------------------------
;
	DB	0		; +36: FDPROG - program length (3)
	DB	0,0,0		; +37-39: specify(03), step/unload(DF), head load(28)
;
;--- CONFI user-configurable parameters --------------------------------------
;
CURSNUM:
	DB	0		; +40: cursor format index (0-3: blink+rev/blink+ul/rev/ul)
CONVNUM:
	DB	0		; +41: conversion table index (0-6: DA/SE/DE/UK/US/FR/LIB)
BAUDNUMA:
	DB	0		; +42: SIO-A baud rate index (0-10: 50..19200 bps)
BAUDNUMB:
	DB	0		; +43: SIO-B baud rate index (0-10: 50..19200 bps)
XYFLG:
	DB	0		; +44: cursor addressing mode (0=H,V  1=V,H)
STPTIM:
	DB	0,0		; +45-46: motor stop timer (word, 1/50s ticks; 250=5sec)
;
;--- Disk type config, CTC2, boot disk (not modified by CONFI) ---------------
;  +47-62: INFD0-INFD15 disk type table   +63: INFDXX terminator (0xFF)
;  +64: NDTAB   +65-67: NDT1   +68-70: CTC2 (MODE4,COUNT4,MODE5)
;  +71: ibootd (boot disk)   +72-127: padding to 128 bytes
;  Values below are residual .COM file data, overwritten by READCB at runtime.
;
	DB	0E5H,0D5H,2AH,0BBH,3AH,0E5H,0E5H
	DB	2AH,96H,3AH,0E5H,21H,0C0H,02H
	DB	0E5H,21H,40H,30H,0E5H,0C5H,0C9H
	DB	0CDH,93H,30H,0C1H,0E1H,0D1H,0CDH
	DB	49H,0DH,0C2H,6FH,30H,3AH,9FH
	DB	3AH,0B7H,0C2H,58H,30H,78H,0B1H
	DB	0C2H,6FH,30H,2AH,91H,3AH,0E5H
	DB	0CDH,0EAH,34H,0E1H,0CDH,0CBH,2CH
	DB	0AFH,32H,9FH,3AH,0D1H,0D5H,2AH
	DB	98H,3AH,0E5H,0EBH,0E9H,0D5H,0CDH
	DB	0C8H,35H,0B7H,0CAH,0A2H,30H,11H
	DB	8DH,38H,0CDH,0DEH
;==============================================================================
